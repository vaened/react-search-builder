{
  "name": "@vaened/react-search-builder",
  "version": "2.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/contexts/index.d.ts",
      "import": "./dist/contexts/index.js",
      "require": "./dist/contexts/index.cjs"
    },
    "./persistence/react-router": {
      "types": "./dist/persistence/react-router/index.d.ts",
      "import": "./dist/persistence/react-router/index.js",
      "require": "./dist/persistence/react-router/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:types": "tsc -p tsconfig.typecheck.json",
    "typecheck": "tsc --noEmit",
    "verify:pack": "node ../../scripts/verify-pack-exports.mjs"
  },
  "peerDependencies": {
    "react": ">=19.2",
    "react-dom": ">=19.2",
    "react-router-dom": ">=7"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "react": "^19.2",
    "react-dom": "^19.2",
    "tsup": "^8.5"
  }
}
